name: Access Directly
desc: Send selected domains and IP addresses directly
mode: rule

dns:
  default-nameserver: #!replace
    - 94.140.14.14
    - 94.140.15.15

  nameserver: #!replace
    - https://dns.adguard-dns.com/dns-query

rules:
  # Apple services directly.
  - GEOSITE,apple,DIRECT

  # Russian domains/services/IPs directly.
  - GEOSITE,category-ru,DIRECT
  - GEOIP,RU,DIRECT
